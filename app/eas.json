{
  "cli": {
    "version": ">= 16.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.13.0",
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "simulator": {
      "extends": "development",
      "node": "22.13.0",
      "ios": {
        "simulator": true
      },
      "channel": "simulator"
    },
    "preview": {
      "node": "22.13.0",
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "production": {
      "node": "22.13.0",
      "environment": "production",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    }
  }
}
